{
  "servers": {
    "jira": {
      "command": "uvx",
      "args": [
        "mcp-atlassian"
      ],
      "envFile": "${workspaceFolder}/.env"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "envFile": "${workspaceFolder}/.env"
    }
  }
}
